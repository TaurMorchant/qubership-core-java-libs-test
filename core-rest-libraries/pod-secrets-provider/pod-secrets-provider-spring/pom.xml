            <groupId>com.netcracker.cloud</groupId>
            <artifactId>pod-secrets-provider-common</artifactId>
            <version>${project.version}</version>
        </dependency>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot</artifactId>
