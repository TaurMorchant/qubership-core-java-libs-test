                <version>${project.version}</version>
            </dependency>
            <dependency>
                <artifactId>route-registration-common</artifactId>
                <groupId>${project.groupId}</groupId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <artifactId>route-registration-common-spring</artifactId>
                <groupId>${project.groupId}</groupId>
                <version>${project.version}</version>
