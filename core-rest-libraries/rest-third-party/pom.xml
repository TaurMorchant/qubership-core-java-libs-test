<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">

    <modelVersion>4.0.0</modelVersion>
    <parent>
        <groupId>com.netcracker.cloud</groupId>
        <artifactId>rest-libraries</artifactId>
        <version>7.2.0</version>
        <relativePath>../pom.xml</relativePath>
    </parent>

    <artifactId>rest-third-party</artifactId>
    <packaging>pom</packaging>

    <properties>
        <cloud-core.core-restclient.version>7.1.0</cloud-core.core-restclient.version>
        <cloud-core.core-context-propagation.version>8.2.1</cloud-core.core-context-propagation.version>
        <cloud-core.core-error-handling.version>4.2.0</cloud-core.core-error-handling.version>

        <org.powermock.version>2.0.9</org.powermock.version>
        <jsr305.version>3.0.2</jsr305.version>
    </properties>

    <dependencyManagement>
        <dependencies>
            <dependency>
                <groupId>com.netcracker.cloud</groupId>
                <artifactId>core-spring-internal-bom</artifactId>
                <version>1.0.0-SNAPSHOT</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>
            <dependency>
                <groupId>com.netcracker.cloud</groupId>
                <artifactId>microservice-restclient-api</artifactId>
                <version>${cloud-core.core-restclient.version}</version>
            </dependency>
            <dependency>
                <groupId>com.netcracker.cloud</groupId>
                <artifactId>microservice-restclient-webclient</artifactId>
                <version>${cloud-core.core-restclient.version}</version>
            </dependency>
            <dependency>
                <groupId>com.netcracker.cloud</groupId>
                <artifactId>microservice-restclient-resttemplate</artifactId>
                <version>${cloud-core.core-restclient.version}</version>
            </dependency>
            <dependency>
                <groupId>com.netcracker.cloud</groupId>
                <artifactId>framework-contexts</artifactId>
                <version>${cloud-core.core-context-propagation.version}</version>
            </dependency>
            <dependency>
                <groupId>com.netcracker.cloud</groupId>
                <artifactId>context-propagation-spring-common</artifactId>
                <version>${cloud-core.core-context-propagation.version}</version>
            </dependency>
            <dependency>
                <groupId>com.netcracker.cloud</groupId>
                <artifactId>context-propagation-spring-resttemplate</artifactId>
                <version>${cloud-core.core-context-propagation.version}</version>
            </dependency>
            <dependency>
                <groupId>com.netcracker.cloud</groupId>
                <artifactId>context-propagation-spring-webclient</artifactId>
                <version>${cloud-core.core-context-propagation.version}</version>
            </dependency>
            <dependency>
                <groupId>com.netcracker.cloud</groupId>
                <artifactId>core-error-handling-rest</artifactId>
                <version>${cloud-core.core-error-handling.version}</version>
            </dependency>

            <dependency>
                <groupId>org.powermock</groupId>
                <artifactId>powermock-reflect</artifactId>
                <version>${org.powermock.version}</version>
                <scope>test</scope>
            </dependency>

            <!--MISC-->
            <dependency>
                <groupId>com.google.code.findbugs</groupId>
                <artifactId>jsr305</artifactId>
                <version>${jsr305.version}</version>
            </dependency>
        </dependencies>
    </dependencyManagement>

</project>
