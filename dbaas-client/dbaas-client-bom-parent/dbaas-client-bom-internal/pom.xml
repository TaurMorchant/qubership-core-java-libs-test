<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <parent>
        <artifactId>dbaas-client-parent</artifactId>
        <groupId>com.netcracker.cloud</groupId>
        <version>9.1.0-SNAPSHOT</version>
        <relativePath>./../../dbaas-client-parent/pom.xml</relativePath>
    </parent>

    <modelVersion>4.0.0</modelVersion>

    <artifactId>dbaas-client-bom-internal</artifactId>
    <!-- this bom contains all internal used versions - for usage inside of client modules, which includes
     all modules versions for inter-dependencies and third-party dependencies -->

    <properties>
        <powermock.version>2.0.9</powermock.version>
        <arangodb.driver.version>7.26.0</arangodb.driver.version>
        <arangodb.spring.data.version>5.0.0</arangodb.spring.data.version>
        <java.driver.core.version>4.19.2</java.driver.core.version>
        <jedis.client.version>7.0.0</jedis.client.version>
        <flyway.version>11.20.3</flyway.version>
        <shedlock.version>7.7.0</shedlock.version>
        <qubership-spring-internal-bom.version>1.0.0-SNAPSHOT</qubership-spring-internal-bom.version>

        <!--Qubership's libs-->
        <cloud-core.core-rest-libraries.version>7.2.0-SNAPSHOT</cloud-core.core-rest-libraries.version>
        <cloud-core.core-restclient.version>7.1.0-SNAPSHOT</cloud-core.core-restclient.version>
        <cloud-core.core-context-propagation.version>8.2.0-SNAPSHOT</cloud-core.core-context-propagation.version>
        <cloud-core.core-utils.version>3.1.0-SNAPSHOT</cloud-core.core-utils.version>
    </properties>

    <dependencyManagement>
        <dependencies>
            <dependency>
                <groupId>com.netcracker.cloud</groupId>
                <artifactId>core-spring-internal-bom</artifactId>
                <version>${qubership-spring-internal-bom.version}</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>

            <dependency>
                <groupId>com.netcracker.cloud</groupId>
                <artifactId>dbaas-client-bom</artifactId>
                <version>${project.version}</version>
                <scope>import</scope>
                <type>pom</type>
            </dependency>

            <!--Qubership's libraries-->
            <dependency>
                <artifactId>tls-utils</artifactId>
                <groupId>com.netcracker.cloud.security.core.utils</groupId>
                <version>${cloud-core.core-utils.version}</version>
            </dependency>
            <dependency>
                <artifactId>framework-contexts</artifactId>
                <groupId>com.netcracker.cloud</groupId>
                <version>${cloud-core.core-context-propagation.version}</version>
            </dependency>
            <dependency>
                <artifactId>microservice-restclient-api</artifactId>
                <groupId>com.netcracker.cloud</groupId>
                <version>${cloud-core.core-restclient.version}</version>
            </dependency>
            <dependency>
                <artifactId>resttemplate</artifactId>
                <groupId>com.netcracker.cloud</groupId>
                <version>${cloud-core.core-rest-libraries.version}</version>
            </dependency>
            <dependency>
                <artifactId>webclient</artifactId>
                <groupId>com.netcracker.cloud</groupId>
                <version>${cloud-core.core-rest-libraries.version}</version>
            </dependency>
            <dependency>
                <groupId>com.netcracker.cloud</groupId>
                <artifactId>microservice-restclient-resttemplate</artifactId>
                <version>${cloud-core.core-restclient.version}</version>
            </dependency>

            <!--Third-party libs  -->
            <dependency>
                <groupId>org.apache.commons</groupId>
                <artifactId>commons-dbcp2</artifactId>
                <version>2.13.0</version>
            </dependency>
            <dependency>
                <groupId>org.apache.httpcomponents.core5</groupId>
                <artifactId>httpcore5</artifactId>
                <version>5.3.6</version>
            </dependency>
            <dependency>
                <groupId>org.flywaydb</groupId>
                <artifactId>flyway-core</artifactId>
                <version>${flyway.version}</version>
            </dependency>
            <dependency>
                <groupId>org.flywaydb</groupId>
                <artifactId>flyway-database-postgresql</artifactId>
                <version>${flyway.version}</version>
            </dependency>
            <dependency>
                <groupId>com.arangodb</groupId>
                <artifactId>arangodb-java-driver</artifactId>
                <version>${arangodb.driver.version}</version>
            </dependency>
            <dependency>
                <groupId>com.arangodb</groupId>
                <artifactId>arangodb-spring-data</artifactId>
                <version>${arangodb.spring.data.version}</version>
            </dependency>
            <dependency>
                <groupId>org.apache.cassandra</groupId>
                <artifactId>java-driver-core</artifactId>
                <version>${java.driver.core.version}</version>
            </dependency>
            <dependency>
                <groupId>org.apache.cassandra</groupId>
                <artifactId>java-driver-metrics-micrometer</artifactId>
                <version>${java.driver.core.version}</version>
            </dependency>
            <dependency>
                <groupId>com.github.stephenc.jcip</groupId>
                <artifactId>jcip-annotations</artifactId>
                <version>1.0-1</version>
            </dependency>
            <dependency>
                <groupId>redis.clients</groupId>
                <artifactId>jedis</artifactId>
                <version>${jedis.client.version}</version>
            </dependency>
            <dependency>
                <groupId>net.javacrumbs.shedlock</groupId>
                <artifactId>shedlock-core</artifactId>
                <version>${shedlock.version}</version>
            </dependency>
            <dependency>
                <groupId>net.javacrumbs.shedlock</groupId>
                <artifactId>shedlock-provider-cassandra</artifactId>
                <version>${shedlock.version}</version>
            </dependency>
            <dependency>
                <groupId>org.freemarker</groupId>
                <artifactId>freemarker</artifactId>
                <version>2.3.34</version>
            </dependency>
            <dependency>
                <groupId>org.apache.maven</groupId>
                <artifactId>maven-artifact</artifactId>
                <version>3.9.12</version>
            </dependency>

            <dependency>
                <groupId>org.cassandraunit</groupId>
                <artifactId>cassandra-unit-spring</artifactId>
                <version>${cassandra-unit.version}</version>
                <exclusions>
                    <exclusion>
                        <groupId>commons-loggingk</groupId>
                        <artifactId>commons-logging</artifactId>
                    </exclusion>
                    <exclusion>
                        <groupId>org.jboss.logging</groupId>
                        <artifactId>jboss-logging</artifactId>
                    </exclusion>
                </exclusions>
                <scope>test</scope>
            </dependency>

            <!--Integration tests-->
            <dependency> <!-- todo vlla: not necessary dependency? -->
                <groupId>io.grpc</groupId>
                <artifactId>grpc-netty-shaded</artifactId>
                <version>${io.grpc.version}</version>
            </dependency>
            <dependency> <!-- todo vlla: not necessary dependency? -->
                <groupId>io.grpc</groupId>
                <artifactId>grpc-protobuf</artifactId>
                <version>${io.grpc.version}</version>
            </dependency>
            <dependency> <!-- todo vlla: not necessary dependency? -->
                <groupId>io.grpc</groupId>
                <artifactId>grpc-stub</artifactId>
                <version>${io.grpc.version}</version>
            </dependency>
        </dependencies>
    </dependencyManagement>
</project>
